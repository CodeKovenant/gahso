# Railway PostgreSQL connection string (set automatically by Railway when you
# attach a PostgreSQL database to this service)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the API listens on (Railway sets this automatically)
PORT=3000

# Restrict CORS to your frontend origin in production
# e.g. https://your-frontend.up.railway.app
ALLOWED_ORIGIN=*

# Set to "production" in Railway
NODE_ENV=production
